@page "/events/{slug}"
@using TheTriadPCNightCrew.Services
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>@(evt?.Name ?? "Evento") | Ticketmaster</PageTitle>

@if (!string.IsNullOrWhiteSpace(error))
{
    <section class="py-5 text-center">
        <div class="container">
            <h1 class="display-4 fw-semibold mb-3">Errore</h1>
            <p class="nc-muted mb-4">@error</p>
            <a class="btn nc-btn" href="/events">Torna alla lista</a>
        </div>
    </section>
}
else if (isLoading)
{
    <section class="py-5 text-center">
        <div class="container">
            <p class="nc-muted">Caricamento evento…</p>
        </div>
    </section>
}
else if (evt is null)
{
    <section class="py-5 text-center">
        <div class="container">
            <h1 class="display-4 fw-semibold mb-3">Evento non trovato</h1>
            <p class="nc-muted mb-4">Lo slug non è valido o l'evento non è più disponibile.</p>
            <a class="btn nc-btn" href="/events">Cerca altri eventi</a>
        </div>
    </section>
}
else
{
    <section class="pb-5">
        <div class="nc-hero rounded-0 mb-5" style="min-height: 45vh; border-bottom: 1px solid var(--nc-border);">
            <img class="nc-hero-bg" src="@(evt.ImageUrl ?? "images/unsplash/hero-home.jpg")" alt="@evt.Name" loading="lazy" />
            <div class="nc-img-gradient" style="background: linear-gradient(180deg, rgba(7,7,11,0) 0%, rgba(7,7,11,0.95) 100%);"></div>

            <div class="container px-3 px-lg-4 position-relative h-100 d-flex align-items-end pb-4" style="z-index: 10;">
                <div class="row w-100">
                    <div class="col-lg-8">
                        <div class="d-flex gap-2 mb-3">
                            @if (!string.IsNullOrWhiteSpace(evt.City))
                            {
                                <span class="nc-chip">@evt.City</span>
                            }
                            <span class="nc-chip nc-chip-strong">Ticketmaster</span>
                        </div>
                        <h1 class="display-4 fw-bold mb-2 nc-article-title">@evt.Name</h1>
                        <p class="lead nc-muted mb-0">@evt.Venue</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="container px-3 px-lg-4">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="nc-card p-4 p-md-5 mb-4">
                        <h2 class="h4 fw-semibold mb-3">Info Evento</h2>
                        @if (!string.IsNullOrWhiteSpace(evt.Description))
                        {
                            <p class="fs-5 nc-muted" style="line-height: 1.7;">@evt.Description</p>
                        }
                        else
                        {
                            <div class="nc-muted" style="line-height: 1.7;">
                                <div class="fw-semibold" style="color: var(--nc-text);">Dettagli rapidi</div>
                                <div>Quando: @FormatDateTime(evt.LocalDate, evt.LocalTime)</div>
                                <div>Dove: @FormatVenueLine(evt.Venue, evt.Address, evt.City)</div>
                                @if (!string.IsNullOrWhiteSpace(evt.Url))
                                {
                                    <div>
                                        Link: <a href="@evt.Url" target="_blank" rel="noopener noreferrer">Apri su Ticketmaster</a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="nc-card p-4 sticky-top" style="top: 6rem;">
                        <div class="mb-4">
                            <div class="nc-muted fs-6 mb-1 text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Quando</div>
                            <div class="fs-5 fw-semibold">@FormatDateTime(evt.LocalDate, evt.LocalTime)</div>
                        </div>
                        
                        <div class="mb-4">
                            <div class="nc-muted fs-6 mb-1 text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Dove</div>
                            <div class="fs-5 fw-semibold">@evt.Venue</div>
                            <div class="nc-muted">@evt.Address</div>
                        </div>

                        <div class="d-grid gap-2">
                            @if (!string.IsNullOrWhiteSpace(evt.Url))
                            {
                                <a class="btn nc-btn btn-lg fw-semibold shadow-none" style="border-radius: 0.75rem;" href="@evt.Url" target="_blank" rel="noopener noreferrer">
                                    Acquista Biglietto
                                </a>
                            }
                            <button class="btn btn-outline-light btn-lg" style="border-radius: 0.75rem; border-color: rgba(255,255,255,0.18);"
                                    @onclick="ToggleFavorite" disabled="@isBusy">
                                @(isFavorite ? "Rimuovi dai Preferiti" : "Salva nei Preferiti")
                            </button>
                            <button class="btn btn-outline-light btn-lg" style="border-radius: 0.75rem; border-color: rgba(255,255,255,0.18);"
                                    @onclick="Share" disabled="@isBusy">
                                Condividi Evento
                            </button>
                            <a class="btn btn-outline-light btn-lg" style="border-radius: 0.75rem; border-color: rgba(255,255,255,0.18);" href="/events">
                                Torna alla lista
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter]
    public string Slug { get; set; } = "";

    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private FavoritesStore Favorites { get; set; } = default!;

    private HttpClient http = default!;
    private TicketmasterApi.TicketmasterEventDetail? evt;
    private bool isLoading;
    private string? error;
    private bool isFavorite;
    private bool isBusy;
    private bool favoriteChecked;

    protected override void OnInitialized()
    {
        http = HttpClientFactory.CreateClient();
        http.BaseAddress = new Uri(Nav.BaseUri);
    }

    protected override async Task OnParametersSetAsync()
    {
        error = null;
        isLoading = true;
        evt = null;
        isFavorite = false;
        favoriteChecked = false;

        try
        {
            if (!TicketmasterSlug.TryExtractId(Slug, out var id))
            {
                evt = null;
                return;
            }

            evt = await http.GetFromJsonAsync<TicketmasterApi.TicketmasterEventDetail>($"/api/ticketmaster/events/{Uri.EscapeDataString(id)}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (favoriteChecked || evt is null)
        {
            return;
        }

        favoriteChecked = true;
        try
        {
            isFavorite = await Favorites.ContainsAsync(evt.Id);
            StateHasChanged();
        }
        catch
        {
        }
    }

    private FavoriteEvent BuildFavorite()
    {
        var id = evt?.Id ?? "";
        var name = evt?.Name ?? "Evento";
        var slug = TicketmasterSlug.Build(name, id);

        return new FavoriteEvent(
            Id: id,
            Slug: slug,
            Name: name,
            City: evt?.City,
            Venue: evt?.Venue,
            Address: evt?.Address,
            LocalDate: evt?.LocalDate,
            LocalTime: evt?.LocalTime,
            ImageUrl: evt?.ImageUrl,
            TicketmasterUrl: evt?.Url,
            AddedAtUtc: DateTimeOffset.UtcNow
        );
    }

    private async Task ToggleFavorite()
    {
        if (evt is null) return;
        if (isBusy) return;
        isBusy = true;
        try
        {
            isFavorite = await Favorites.ToggleAsync(BuildFavorite());
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private async Task Share()
    {
        if (evt is null) return;
        if (isBusy) return;
        isBusy = true;
        try
        {
            var slug = TicketmasterSlug.Build(evt.Name, evt.Id);
            var url = $"{Nav.BaseUri.TrimEnd('/')}/events/{Uri.EscapeDataString(slug)}";
            await JS.InvokeVoidAsync("ncShare.share", new { title = evt.Name, text = evt.Venue, url });
        }
        finally
        {
            isBusy = false;
        }
    }

    private static string FormatDateTime(string? localDate, string? localTime)
    {
        if (string.IsNullOrWhiteSpace(localDate))
        {
            return "Data da confermare";
        }

        return string.IsNullOrWhiteSpace(localTime) ? localDate : $"{localDate} · {localTime}";
    }

    private static string FormatVenueLine(string? venue, string? address, string? city)
    {
        var v = (venue ?? "").Trim();
        var a = (address ?? "").Trim();
        var c = (city ?? "").Trim();

        if (v.Length == 0 && a.Length == 0 && c.Length == 0) return "Da confermare";
        if (a.Length == 0 && c.Length == 0) return v;
        if (a.Length == 0) return v.Length == 0 ? c : $"{v} · {c}";
        if (c.Length == 0) return v.Length == 0 ? a : $"{v} · {a}";
        if (v.Length == 0) return $"{a} · {c}";
        return $"{v} · {a} · {c}";
    }
}
