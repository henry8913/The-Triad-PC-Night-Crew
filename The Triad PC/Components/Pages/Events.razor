@page "/events"
@using TheTriadPCNightCrew.Services
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Eventi</PageTitle>

<section class="py-5">
    <div class="container px-3 px-lg-4">
        <div class="nc-hero mb-4">
            <img class="nc-hero-bg" src="images/unsplash/hero-home.jpg" alt="Neon street at night" loading="lazy" />
            <div class="nc-hero-overlay"></div>
            <div class="nc-hero-content">
                <div class="nc-kicker mb-2">Esplora</div>
                <h1 class="display-5 fw-semibold mb-2">Eventi in arrivo</h1>
                <div class="nc-muted">Filtra per città, mood e data. I dati API arrivano qui.</div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-4">
                <div class="nc-card p-3 p-md-4">
                    <div class="fw-semibold mb-2">Filtri</div>
                    <div class="nc-muted mb-3">Ticketmaster (server-side): data, distanza e “vicino a me”.</div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Quando</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button" class="btn btn-sm @(when == WhenFilter.Today ? "nc-btn" : "btn-outline-light")"
                                    style="border-color: rgba(255,255,255,0.18);" @onclick="() => SetWhen(WhenFilter.Today)">
                                Oggi
                            </button>
                            <button type="button" class="btn btn-sm @(when == WhenFilter.Weekend ? "nc-btn" : "btn-outline-light")"
                                    style="border-color: rgba(255,255,255,0.18);" @onclick="() => SetWhen(WhenFilter.Weekend)">
                                Weekend
                            </button>
                            <button type="button" class="btn btn-sm @(when == WhenFilter.ThisWeek ? "nc-btn" : "btn-outline-light")"
                                    style="border-color: rgba(255,255,255,0.18);" @onclick="() => SetWhen(WhenFilter.ThisWeek)">
                                Questa settimana
                            </button>
                            <button type="button" class="btn btn-sm @(when == WhenFilter.All ? "nc-btn" : "btn-outline-light")"
                                    style="border-color: rgba(255,255,255,0.18);" @onclick="() => SetWhen(WhenFilter.All)">
                                Tutti
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Distanza (km)</label>
                        <select class="form-select nc-select" @bind="radiusKm" disabled="@(!nearMe)">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div class="form-text nc-muted" style="opacity: .8;">
                            La distanza funziona solo con “Vicino a me”.
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label mb-0 nc-muted">Vicino a me</label>
                            <div class="form-check form-switch m-0">
                                <input class="form-check-input" type="checkbox" role="switch" checked="@nearMe" @onchange="OnNearMeChanged" />
                            </div>
                        </div>

                        @if (nearMe)
                        {
                            <div class="d-grid mt-2">
                                <button class="btn btn-outline-light" style="border-color: rgba(255,255,255,0.18);"
                                        @onclick="GetLocation" disabled="@isLocating">
                                    @(isLocating ? "Sto rilevando la posizione…" : (HasCoords ? "Posizione aggiornata" : "Usa la mia posizione"))
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(geoError))
                            {
                                <div class="nc-muted mt-2" style="color: rgba(255,77,0,0.95);">
                                    @geoError
                                </div>
                            }
                            <div class="nc-muted mt-2">
                                La città viene ignorata quando “Vicino a me” è attivo.
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Città</label>
                        <input class="form-control nc-input" @bind="city" @bind:event="oninput" placeholder="Roma" disabled="@nearMe" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Keyword</label>
                        <input class="form-control nc-input" @bind="keyword" @bind:event="oninput" placeholder="techno, jazz, live..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Genere</label>
                        <select class="form-select nc-select" @bind="classificationName">
                            <option value="">Qualsiasi</option>
                            <option value="Jazz">Jazz</option>
                            <option value="Techno">Techno</option>
                            <option value="Live">Live</option>
                            <option value="Club">Club</option>
                            <option value="Comedy">Comedy</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label mb-1 nc-muted">Risultati per pagina</label>
                        <select class="form-select nc-select" @bind="size">
                            <option value="6">6</option>
                            <option value="12">12</option>
                            <option value="24">24</option>
                        </select>
                    </div>

                    <button class="btn nc-btn w-100" @onclick="Apply" disabled="@isLoading">Applica</button>
                </div>
            </div>

            <div class="col-lg-8">
                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="nc-card p-4">
                        <div class="fw-semibold mb-1">Errore</div>
                        <div class="nc-muted">@error</div>
                    </div>
                }
                else if (isLoading)
                {
                    <div class="nc-card p-4">
                        <div class="nc-muted">Caricamento eventi…</div>
                    </div>
                }
                else if (items.Count == 0)
                {
                    <div class="nc-card p-4">
                        <div class="fw-semibold mb-1">Nessun evento trovato</div>
                        <div class="nc-muted">Prova a cambiare keyword o città.</div>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var e in items)
                        {
                            <div class="col-12 col-md-6">
                                <a href="/events/@TicketmasterSlug.Build(e.Name, e.Id)" class="text-decoration-none d-block h-100">
                                    <div class="nc-card nc-card-hover h-100 overflow-hidden d-flex flex-column">
                                        <div class="nc-img-wrap">
                                            <img class="nc-img" src="@(e.ImageUrl ?? "images/unsplash/hero-home.jpg")" alt="@e.Name" loading="lazy" />
                                            <div class="nc-img-gradient"></div>
                                            <div class="nc-img-badges">
                                                @if (!string.IsNullOrWhiteSpace(e.Genre))
                                                {
                                                    <span class="nc-chip nc-chip-strong">@e.Genre</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(e.City))
                                                {
                                                    <span class="nc-chip">@e.City</span>
                                                }
                                            </div>
                                        </div>

                                        <div class="p-3 flex-grow-1 d-flex flex-column">
                                            <div class="fw-semibold fs-5 mb-1 nc-article-title" style="color: var(--nc-text);">@e.Name</div>
                                            <div class="nc-muted mb-3 flex-grow-1">@e.Venue</div>
                                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                                <span class="nc-muted">@FormatDateTime(e.LocalDate, e.LocalTime)</span>
                                                <span class="nc-chip nc-chip-strong">Dettagli</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-2">
                        <div class="nc-muted">
                            Mostrati @items.Count di @(resultMeta?.TotalItems ?? (long)items.Count)
                        </div>

                        @if (CanLoadMore)
                        {
                            <button class="btn btn-outline-light" style="border-color: rgba(255,255,255,0.18);"
                                    @onclick="LoadMore" disabled="@isLoading">
                                Carica altri
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private HttpClient http = default!;
    private static readonly System.Text.Json.JsonSerializerOptions JsonOptions = new(System.Text.Json.JsonSerializerDefaults.Web);

    private TicketmasterApi.PagedResult<TicketmasterApi.TicketmasterEventListItem>? resultMeta;
    private readonly List<TicketmasterApi.TicketmasterEventListItem> items = new();
    private bool isLoading;
    private string? error;

    private string keyword = "";
    private string city = "Roma";
    private string classificationName = "";
    private WhenFilter when = WhenFilter.All;
    private int radiusKm = 50;
    private bool nearMe;
    private double? lat;
    private double? lng;
    private bool isLocating;
    private string? geoError;
    private int page = 0;
    private int initialPageFromUrl = 0;
    private int size = 24;

    protected override async Task OnInitializedAsync()
    {
        http = HttpClientFactory.CreateClient();
        http.BaseAddress = new Uri(Nav.BaseUri);
        ReadQueryString();
        await LoadInitial();
    }

    private void ReadQueryString()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        keyword = q.TryGetValue("keyword", out var kw) ? kw.ToString() : keyword;
        city = q.TryGetValue("city", out var c) ? c.ToString() : city;
        classificationName = q.TryGetValue("genre", out var g) ? g.ToString() : classificationName;

        if (q.TryGetValue("when", out var w))
        {
            when = w.ToString().ToLowerInvariant() switch
            {
                "oggi" or "today" => WhenFilter.Today,
                "weekend" => WhenFilter.Weekend,
                "questa-settimana" or "thisweek" or "this-week" or "week" => WhenFilter.ThisWeek,
                "tutti" or "all" => WhenFilter.All,
                _ => WhenFilter.All
            };
        }

        if (q.TryGetValue("near", out var n))
        {
            nearMe = n.ToString() == "1" || n.ToString().Equals("true", StringComparison.OrdinalIgnoreCase);
        }

        if (q.TryGetValue("radius", out var r) && int.TryParse(r.ToString(), out var parsedRadius))
        {
            radiusKm = parsedRadius;
        }
        else if (nearMe)
        {
            radiusKm = 50;
        }

        if (q.TryGetValue("lat", out var la) && double.TryParse(la.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedLat))
        {
            lat = parsedLat;
        }

        if (q.TryGetValue("lng", out var ln) && double.TryParse(ln.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedLng))
        {
            lng = parsedLng;
        }

        if (q.TryGetValue("page", out var p) && int.TryParse(p.ToString(), out var parsedPage))
        {
            initialPageFromUrl = Math.Max(0, parsedPage);
        }

        if (q.TryGetValue("size", out var s) && int.TryParse(s.ToString(), out var parsedSize))
        {
            size = Math.Clamp(parsedSize, 1, 200);
        }
    }

    private async Task Apply()
    {
        initialPageFromUrl = 0;
        page = 0;
        await EnsureLocationIfNeeded();
        SyncUrl(replace: true);
        await LoadInitial();
    }

    private void SetWhen(WhenFilter value)
    {
        when = value;
    }

    private async Task OnNearMeChanged(ChangeEventArgs e)
    {
        var enabled = e.Value is bool b
            ? b
            : string.Equals(e.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);

        if (nearMe == enabled)
        {
            return;
        }

        nearMe = enabled;
        geoError = null;
        lat = null;
        lng = null;

        if (nearMe)
        {
            radiusKm = 50;
            when = WhenFilter.All;
            classificationName = "";
        }

        await Task.CompletedTask;
    }

    private bool HasCoords => lat is not null && lng is not null;

    private async Task EnsureLocationIfNeeded()
    {
        if (!nearMe) return;
        if (HasCoords) return;
        await GetLocation();
    }

    private async Task GetLocation()
    {
        geoError = null;
        isLocating = true;
        StateHasChanged();

        try
        {
            var pos = await JS.InvokeAsync<GeoPosition>("ncGeo.getCurrentPosition");
            lat = pos.Latitude;
            lng = pos.Longitude;
        }
        catch (Exception ex)
        {
            geoError = ex.Message;
            lat = null;
            lng = null;
        }
        finally
        {
            isLocating = false;
            StateHasChanged();
        }
    }

    private (DateTimeOffset? StartUtc, DateTimeOffset? EndUtc) BuildDateRangeUtc()
    {
        var today = DateTime.Today;
        var offset = TimeZoneInfo.Local.GetUtcOffset(today);

        DateTime startLocal;
        DateTime endLocal;

        switch (when)
        {
            case WhenFilter.Today:
                startLocal = today;
                endLocal = today.AddDays(1).AddTicks(-1);
                break;

            case WhenFilter.ThisWeek:
                startLocal = today;
                endLocal = today.AddDays(7).AddTicks(-1);
                break;

            case WhenFilter.Weekend:
                if (today.DayOfWeek == DayOfWeek.Sunday)
                {
                    startLocal = today.AddDays(-1);
                }
                else
                {
                    var daysUntilSat = ((int)DayOfWeek.Saturday - (int)today.DayOfWeek + 7) % 7;
                    startLocal = today.AddDays(daysUntilSat);
                }
                endLocal = startLocal.AddDays(2).AddTicks(-1);
                break;

            default:
                return (null, null);
        }

        var start = new DateTimeOffset(startLocal, offset).ToUniversalTime();
        var end = new DateTimeOffset(endLocal, offset).ToUniversalTime();
        return (start, end);
    }

    private void SyncUrl(bool replace)
    {
        var p = new Dictionary<string, string?>();

        if (!string.IsNullOrWhiteSpace(keyword)) p["keyword"] = keyword;
        if (!nearMe && !string.IsNullOrWhiteSpace(city)) p["city"] = city;
        if (!string.IsNullOrWhiteSpace(classificationName)) p["genre"] = classificationName;

        if (when != WhenFilter.All)
        {
            p["when"] = when switch
            {
                WhenFilter.Today => "today",
                WhenFilter.Weekend => "weekend",
                WhenFilter.ThisWeek => "this-week",
                _ => "all"
            };
        }

        if (nearMe) p["near"] = "1";
        if (nearMe) p["radius"] = radiusKm.ToString();

        if (HasCoords)
        {
            p["lat"] = lat!.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture);
            p["lng"] = lng!.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture);
        }

        if (page > 0) p["page"] = page.ToString();
        if (size != 12) p["size"] = size.ToString();

        var url = Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/events", p);
        Nav.NavigateTo(url, replace: replace);
    }

    private bool CanLoadMore =>
        !isLoading &&
        resultMeta is not null &&
        page + 1 < resultMeta.TotalPages;

    private async Task LoadMore()
    {
        if (!CanLoadMore) return;
        error = null;
        isLoading = true;
        StateHasChanged();

        try
        {
            page++;
            SyncUrl(replace: true);
            await LoadPage(page, append: true);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadInitial()
    {
        error = null;
        isLoading = true;
        items.Clear();
        resultMeta = null;
        StateHasChanged();

        try
        {
            page = 0;
            var target = Math.Max(0, initialPageFromUrl);
            for (var p = 0; p <= target; p++)
            {
                await LoadPage(p, append: p > 0);
                page = p;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPage(int pageToLoad, bool append)
    {
        try
        {
            var (startUtc, endUtc) = BuildDateRangeUtc();
            var latlong = (nearMe && HasCoords) ? $"{lat!.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)},{lng!.Value.ToString("0.######", System.Globalization.CultureInfo.InvariantCulture)}" : null;
            var radius = (nearMe && HasCoords) ? radiusKm : (int?)null;

            var q = new List<KeyValuePair<string, string?>>();
            void Add(string key, string? value)
            {
                if (!string.IsNullOrWhiteSpace(value))
                {
                    q.Add(new(key, value));
                }
            }

            Add("keyword", keyword);
            if (!nearMe) Add("city", city);
            Add("classificationName", classificationName);
            Add("page", pageToLoad.ToString());
            Add("size", size.ToString());

            if (startUtc is not null) Add("startDateTime", startUtc.Value.ToString("O"));
            if (endUtc is not null) Add("endDateTime", endUtc.Value.ToString("O"));
            if (!string.IsNullOrWhiteSpace(latlong)) Add("latLong", latlong);
            if (radius is not null) Add("radius", radius.Value.ToString());
            if (nearMe && HasCoords) Add("unit", "km");

            var url = Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/api/ticketmaster/events", q);

            using var response = await http.GetAsync(url);
            var content = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                var problem = TryParseProblemDetails(content);
                throw new InvalidOperationException(BuildUserFriendlyError(problem, response.StatusCode));
            }

            var resp = System.Text.Json.JsonSerializer.Deserialize<TicketmasterApi.PagedResult<TicketmasterApi.TicketmasterEventListItem>>(content, JsonOptions);
            resultMeta = resp;

            if (resp is null)
            {
                return;
            }

            if (!append)
            {
                items.Clear();
            }

            items.AddRange(resp.Items);
        }
        catch
        {
            throw;
        }
    }

    private static string FormatDateTime(string? localDate, string? localTime)
    {
        if (string.IsNullOrWhiteSpace(localDate))
        {
            return "Data da confermare";
        }

        return string.IsNullOrWhiteSpace(localTime) ? localDate : $"{localDate} · {localTime}";
    }

    private sealed record GeoPosition(double Latitude, double Longitude, double? Accuracy);

    private static Microsoft.AspNetCore.Mvc.ProblemDetails? TryParseProblemDetails(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return null;
        }

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<Microsoft.AspNetCore.Mvc.ProblemDetails>(json, JsonOptions);
        }
        catch
        {
            return null;
        }
    }

    private static string BuildUserFriendlyError(Microsoft.AspNetCore.Mvc.ProblemDetails? problem, System.Net.HttpStatusCode statusCode)
    {
        if (!string.IsNullOrWhiteSpace(problem?.Detail))
        {
            return problem!.Detail!;
        }

        if (!string.IsNullOrWhiteSpace(problem?.Title))
        {
            return problem!.Title!;
        }

        var status = problem?.Status ?? (int)statusCode;
        return $"Errore nel caricamento degli eventi ({status}). Riprova tra poco.";
    }

    private enum WhenFilter
    {
        Today,
        Weekend,
        ThisWeek,
        All
    }
}
