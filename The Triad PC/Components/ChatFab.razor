@rendermode InteractiveServer

<button class="nc-chat-fab" type="button" @onclick="Toggle" aria-label="Apri chat con Gabo">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3v18" />
        <path d="m3 12 18 0" />
        <path d="m8.5 8.5 7 7" />
        <path d="m15.5 8.5-7 7" />
        <circle cx="12" cy="12" r="3" fill="currentColor" opacity="0.3" />
    </svg>
</button>

<div class="nc-chat-panel @(isOpen ? "is-open" : "")" role="dialog" aria-label="Chat Gabo" aria-modal="false">
    <div class="nc-chat-panel-header">
        <div class="nc-chat-title">
            <div class="nc-chat-title-main">Gabo AI</div>
            <div class="nc-chat-title-sub">Assistente Night Crew</div>
        </div>
        <button class="nc-chat-close" type="button" @onclick="Close" aria-label="Chiudi chat">✕</button>
    </div>

    <div class="nc-chat-messages">
        @foreach (var m in messages)
        {
            <div class="nc-chat-msg @(m.Role == ChatRole.User ? "is-user" : "is-bot")">
                <div class="nc-chat-bubble">@m.Text</div>
            </div>
        }
    </div>

    <div class="nc-chat-input">
        <input class="form-control nc-input"
               @bind="draft"
               @bind:event="oninput"
               placeholder="Scrivi a Gabo…"
               @onkeydown="OnKeyDown" />
        <button class="btn nc-btn" type="button" @onclick="Send" disabled="@(isSending || string.IsNullOrWhiteSpace(draft))">Invia</button>
    </div>
</div>

@code {
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool isOpen;
    private string draft = "";
    private bool isSending;
    private readonly List<ChatMessage> messages =
    [
        new(ChatRole.Bot, "Ciao! Scegli città e mood: ti trovo gli eventi di stasera. Prova “Milano techno” o “Roma jazz”.")
    ];

    private void Toggle() => isOpen = !isOpen;
    private void Close() => isOpen = false;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task Send()
    {
        var text = draft.Trim();
        if (text.Length == 0)
        {
            return;
        }

        messages.Add(new(ChatRole.User, text));
        draft = "";
        isOpen = true;
        isSending = true;

        var typing = new ChatMessage(ChatRole.Bot, "…");
        messages.Add(typing);
        StateHasChanged();

        try
        {
            var payload = new
            {
                messages = messages
                    .Where(m => m.Text != "…")
                    .Select(m => new
                    {
                        role = m.Role == ChatRole.User ? "user" : "assistant",
                        content = m.Text
                    })
            };

            var http = HttpClientFactory.CreateClient();
            http.BaseAddress = new Uri(Nav.BaseUri);

            using var resp = await http.PostAsJsonAsync("/chat", payload);
            var body = await resp.Content.ReadAsStringAsync();

            var replyText = TryExtractReplyText(body) ??
                            (resp.IsSuccessStatusCode ? body : $"Errore chat ({(int)resp.StatusCode}): {body}");

            messages.Remove(typing);
            messages.Add(new(ChatRole.Bot, replyText));
        }
        catch (Exception ex)
        {
            messages.Remove(typing);
            messages.Add(new(ChatRole.Bot, $"Errore chat: {ex.Message}"));
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

    private static string? TryExtractReplyText(string body)
    {
        if (string.IsNullOrWhiteSpace(body))
        {
            return null;
        }

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(body);
            var root = doc.RootElement;

            if (root.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                if (root.TryGetProperty("reply", out var reply) && reply.ValueKind == System.Text.Json.JsonValueKind.String)
                    return reply.GetString();

                if (root.TryGetProperty("detail", out var detail) && detail.ValueKind == System.Text.Json.JsonValueKind.String)
                    return detail.GetString();

                if (root.TryGetProperty("error", out var err) && err.ValueKind == System.Text.Json.JsonValueKind.String)
                    return err.GetString();

                if (root.TryGetProperty("text", out var text) && text.ValueKind == System.Text.Json.JsonValueKind.String)
                    return text.GetString();

                if (root.TryGetProperty("content", out var content) && content.ValueKind == System.Text.Json.JsonValueKind.String)
                    return content.GetString();

                if (root.TryGetProperty("title", out var title) && title.ValueKind == System.Text.Json.JsonValueKind.String)
                    return title.GetString();

                if (root.TryGetProperty("choices", out var choices) &&
                    choices.ValueKind == System.Text.Json.JsonValueKind.Array &&
                    choices.GetArrayLength() > 0)
                {
                    var c0 = choices[0];
                    if (c0.TryGetProperty("message", out var msg) &&
                        msg.ValueKind == System.Text.Json.JsonValueKind.Object &&
                        msg.TryGetProperty("content", out var c) &&
                        c.ValueKind == System.Text.Json.JsonValueKind.String)
                    {
                        return c.GetString();
                    }
                }
            }
        }
        catch
        {
        }

        return null;
    }

    private enum ChatRole
    {
        User,
        Bot
    }

    private sealed record ChatMessage(ChatRole Role, string Text);
}
